{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainlayer.dev/schemas/belief.schema.json",
  "title": "Belief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "key",
    "proposition",
    "value",
    "confidence",
    "status",
    "evidence_episode_ids",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "proposition": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded"]
    },
    "evidence_episode_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
