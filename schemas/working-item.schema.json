{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainlayer.dev/schemas/working-item.schema.json",
  "title": "WorkingItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "key",
    "value",
    "content",
    "priority",
    "status",
    "source_refs",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "priority": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "done"]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
