{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainlayer.dev/schemas/episode.schema.json",
  "title": "Episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "scenario",
    "summary",
    "tags",
    "salience",
    "outcome",
    "source_refs",
    "timestamp"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "salience": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "outcome": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
