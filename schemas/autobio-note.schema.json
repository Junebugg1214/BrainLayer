{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainlayer.dev/schemas/autobio-note.schema.json",
  "title": "AutobioNote",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "key",
    "value",
    "summary",
    "themes",
    "supporting_ids",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supporting_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
