{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainlayer.dev/schemas/procedure.schema.json",
  "title": "Procedure",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "trigger",
    "summary",
    "steps",
    "confidence",
    "derived_from",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "trigger": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "derived_from": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
